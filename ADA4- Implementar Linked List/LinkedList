if __name__ == "__main__":

    sep = lambda t: print(f"\n{'═'*60}\n  {t}\n{'═'*60}")

    # ── Lista Simple ──────────────────────────────────────────
    sep("LISTA ENLAZADA SIMPLE")

    ll = SinglyLinkedList.from_list([3, 1, 4, 1, 5, 9, 2, 6])
    print("Creada desde lista: ", ll)
    print("Tamaño:             ", len(ll))
    print("5 in lista:         ", 5 in ll)
    print("Búsqueda de 9:      ", ll.search(9), "(índice)")
    print("Elemento [3]:       ", ll[3])
    print("Elemento [-1]:      ", ll[-1])
    print("Nodo del medio:     ", ll.find_middle())

    ll.append(99)
    ll.prepend(0)
    ll.insert_at(3, 77)
    print("\nTras append(99), prepend(0), insert_at(3, 77):")
    print(" ", ll)

    ll.remove(1)        # elimina primer '1'
    ll.remove_at(0)     # elimina head (0)
    print("\nTras remove(1) y remove_at(0):")
    print(" ", ll)

    print("\nIteración for-in: ", [x for x in ll])
    print("Conteo de 1:      ", ll.count(1))

    copia = ll.copy()
    copia.reverse()
    print("\nCopia invertida:  ", copia)

    ll3 = SinglyLinkedList.from_list([5, 3, 8, 1, 9, 2, 7])
    ll3.merge_sort()
    print("\nMerge Sort [5,3,8,1,9,2,7] →", ll3)

    ll4 = SinglyLinkedList.from_list([1, 2, 3, 2, 1, 4, 3])
    ll4.remove_duplicates()
    print("\nElim. duplicados [1,2,3,2,1,4,3] →", ll4)

    print("\n¿Tiene ciclo?:     ", ll.has_cycle())

    # ── Lista Doble ───────────────────────────────────────────
    sep("LISTA ENLAZADA DOBLE")

    dl = DoublyLinkedList()
    for v in [10, 20, 30, 40, 50]:
        dl.append(v)
    print("Lista:             ", dl)
    print("Reversa:           ", list(reversed(dl)))

    dl.prepend(5)
    dl.insert_after(30, 35)
    print("\nTras prepend(5) e insert_after(30, 35):")
    print(" ", dl)

    print("\npop_front() →", dl.pop_front())
    print("pop_back()  →", dl.pop_back())
    print("Lista final: ", dl)

    # ── Lista Circular ────────────────────────────────────────
    sep("LISTA ENLAZADA CIRCULAR")

    cl = CircularLinkedList()
    for v in ["X", "Y", "Z", "W", "V"]:
        cl.append(v)
    print("Circular:          ", cl)
    print("Como list Python:  ", cl.to_list())

    cl.remove("Z")
    cl.prepend("A")
    print("\nTras remove('Z') y prepend('A'):")
    print(" ", cl)

    cl2 = CircularLinkedList()
    for i in range(1, 8):
        cl2.append(i)
    print(f"\nJosephus (n=7, k=3): superviviente = {cl2.josephus(k=3)}")
