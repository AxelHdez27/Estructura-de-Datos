    def _btn(self, parent, text, cmd, fg=GREEN, abg=None, width=None):
        kw = dict(font=("Courier New", 8, "bold"), fg=fg,
                  bg=DARK_BG, activeforeground=BG,
                  activebackground=fg if abg is None else abg,
                  relief="flat", bd=0, cursor="hand2",
                  highlightthickness=1, highlightbackground=fg,
                  padx=8, pady=6, command=cmd)
        if width:
            kw["width"] = width
        return tk.Button(parent, text=text, **kw)

    # ═══════════════════════════════════════════════════════
    #  RENDERIZADO DEL CANVAS
    # ═══════════════════════════════════════════════════════
    def _render(self, anim_push_idx=None, anim_pop_offset=None):
        """Dibuja la pila completa. 
           anim_push_idx: índice del elemento que está entrando (se dibuja desplazado).
           anim_pop_offset: píxeles hacia la derecha del elemento que está saliendo.
        """
        c = self.canvas
        c.delete("all")
        W = CANVAS_W
        base_y = CANVAS_H - 20

        datos = self.pila.to_list()
        n = len(datos)

        # Paredes
        wall_xl = (W - ITEM_W) // 2 - 5
        wall_xr = (W + ITEM_W) // 2 + 5
        wall_top = max(10, base_y - n * ITEM_H - 30)
        c.create_rectangle(wall_xl, wall_top, wall_xl + 4, base_y, fill=GREEN_DIM, outline="")
        c.create_rectangle(wall_xr - 4, wall_top, wall_xr, base_y, fill=GREEN_DIM, outline="")

        # Base
        c.create_rectangle(wall_xl, base_y, wall_xr, base_y + 6, fill=GREEN, outline="")

        # Etiqueta vacío
        if not datos:
            c.create_text(W // 2, base_y - 50,
                          text="[ PILA VACIA ]", font=("Courier New", 9), fill=BORDER)
        else:
            for i, val in enumerate(datos):
                y_bot = base_y - i * ITEM_H
                y_top = y_bot - ITEM_H
                x_l   = (W - ITEM_W) // 2
                x_r   = (W + ITEM_W) // 2

                is_top    = (i == n - 1)
                in_hl     = (i in self.highlight)
                is_anim_p = (anim_push_idx is not None and i == anim_push_idx)
                is_anim_o = (anim_pop_offset is not None and i == n - 1)

                # Desplazamiento de animación
                dx, dy = 0, 0
                if is_anim_p:
                    dy = anim_push_idx * 0  # empuja desde arriba
                if is_anim_o:
                    dx = anim_pop_offset

                # Colores
                if in_hl and self.hl_color == BLUE:
                    fill, border_c, text_c = "#002a40", BLUE, BLUE
                elif in_hl:
                    fill, border_c, text_c = "#2a1500", AMBER, AMBER
                elif is_top:
                    fill, border_c, text_c = "#002a15", GREEN, GREEN
                else:
                    fill, border_c, text_c = "#001a0d", GREEN_DIM, GREEN

                bw = 2 if (is_top or in_hl) else 1

                c.create_rectangle(x_l + dx, y_top + dy, x_r + dx, y_bot + dy,
                                   fill=fill, outline=border_c, width=bw)

                # Índice
                c.create_text(x_l + dx + 14, (y_top + y_bot) // 2 + dy,
                              text=f"[{i}]", font=("Courier New", 8),
                              fill=GREEN_DIM, anchor="w")

                # Valor
                c.create_text(W // 2 + dx, (y_top + y_bot) // 2 + dy,
                              text=str(val), font=("Courier New", 12, "bold"),
                              fill=text_c)

                # Dirección
                addr = f"0x{0x1000 + i * 4:04X}"
                c.create_text(x_r + dx - 10, (y_top + y_bot) // 2 + dy,
                              text=addr, font=("Courier New", 7),
                              fill="#003322", anchor="e")

                # Etiqueta TOP
                if is_top and anim_pop_offset is None:
                    c.create_text(x_r + dx + 36, (y_top + y_bot) // 2 + dy,
                                  text="<TOP", font=("Courier New", 7, "bold"),
                                  fill=GREEN)

        self._update_widgets()

    def _update_widgets(self):
        n = len(self.pila)
        has = n > 0
        for btn_name in ("btn_pop", "btn_peek", "btn_clear"):
            if hasattr(self, btn_name):
                getattr(self, btn_name).config(state="normal" if has else "disabled")
        self.btn_undo.config(state="normal" if self._historial else "disabled")
        self.lbl_size.config(text=str(n))
        self.lbl_ops.config(text=str(self.total_ops))
        self.lbl_hist.config(text=str(len(self._historial)))

    # ═══════════════════════════════════════════════════════
    #  ANIMACIONES
    # ═══════════════════════════════════════════════════════
    def _anim_push(self, callback):
        """Anima el elemento del tope entrando desde arriba."""
        idx = len(self.pila) - 1
        steps = ANIM_STEPS
        step  = [0]

        def frame():
            progress = step[0] / steps
            # ease-out: empieza rápido, termina suave
            ease = 1 - (1 - progress) ** 3
            offset_y = int((1 - ease) * -ITEM_H)
            self._render_push_frame(idx, offset_y)
            step[0] += 1
            if step[0] <= steps:
                self._anim_job = self.root.after(ANIM_DELAY, frame)
            else:
                self._render()
                if callback:
                    callback()

        frame()

    def _render_push_frame(self, top_idx, offset_y):
        """Renderiza todos los elementos; el tope aparece con offset_y."""
        c = self.canvas
        c.delete("all")
        W = CANVAS_W
        base_y = CANVAS_H - 20
        datos = self.pila.to_list()
        n = len(datos)

        wall_xl = (W - ITEM_W) // 2 - 5
        wall_xr = (W + ITEM_W) // 2 + 5
        wall_top = max(10, base_y - n * ITEM_H - 30)
        c.create_rectangle(wall_xl, wall_top, wall_xl + 4, base_y, fill=GREEN_DIM, outline="")
        c.create_rectangle(wall_xr - 4, wall_top, wall_xr, base_y, fill=GREEN_DIM, outline="")
        c.create_rectangle(wall_xl, base_y, wall_xr, base_y + 6, fill=GREEN, outline="")

        for i, val in enumerate(datos):
            y_bot = base_y - i * ITEM_H
            y_top = y_bot - ITEM_H
            x_l   = (W - ITEM_W) // 2
            x_r   = (W + ITEM_W) // 2
            dy    = offset_y if i == top_idx else 0

            is_top = (i == n - 1)
            fill   = "#002a15" if is_top else "#001a0d"
            border = GREEN    if is_top else GREEN_DIM

            c.create_rectangle(x_l, y_top + dy, x_r, y_bot + dy,
                               fill=fill, outline=border, width=2 if is_top else 1)
            c.create_text(x_l + 14, (y_top + y_bot) // 2 + dy,
                          text=f"[{i}]", font=("Courier New", 8), fill=GREEN_DIM, anchor="w")
            c.create_text(W // 2, (y_top + y_bot) // 2 + dy,
                          text=str(val), font=("Courier New", 12, "bold"), fill=GREEN)

    def _anim_pop(self, val_removido, callback):
        """Anima el elemento del tope saliendo hacia la derecha."""
        steps = ANIM_STEPS
        step  = [0]
        max_offset = CANVAS_W

        def frame():
            progress  = step[0] / steps
            ease      = progress ** 2  # aceleración
            offset_x  = int(ease * max_offset)
            self._render_pop_frame(offset_x)
            step[0] += 1
            if step[0] <= steps:
                self._anim_job = self.root.after(ANIM_DELAY, frame)
            else:
                self._render()
                if callback:
                    callback()

        frame()

    def _render_pop_frame(self, offset_x):
        """Renderiza todos; el tope se mueve a la derecha."""
        c = self.canvas
        c.delete("all")
        W = CANVAS_W
        base_y = CANVAS_H - 20
        datos = self.pila.to_list()
        n = len(datos)

        wall_xl = (W - ITEM_W) // 2 - 5
        wall_xr = (W + ITEM_W) // 2 + 5
        wall_top = max(10, base_y - (n + 1) * ITEM_H - 30)
        c.create_rectangle(wall_xl, wall_top, wall_xl + 4, base_y, fill=GREEN_DIM, outline="")
        c.create_rectangle(wall_xr - 4, wall_top, wall_xr, base_y, fill=GREEN_DIM, outline="")
        c.create_rectangle(wall_xl, base_y, wall_xr, base_y + 6, fill=GREEN, outline="")

        # Dibuja los que quedan (índices 0..n-1) normal
        for i, val in enumerate(datos):
            y_bot = base_y - i * ITEM_H
            y_top = y_bot - ITEM_H
            x_l   = (W - ITEM_W) // 2
            x_r   = (W + ITEM_W) // 2
            c.create_rectangle(x_l, y_top, x_r, y_bot,
                               fill="#001a0d", outline=GREEN_DIM)
            c.create_text(x_l + 14, (y_top + y_bot) // 2,
                          text=f"[{i}]", font=("Courier New", 8), fill=GREEN_DIM, anchor="w")
            c.create_text(W // 2, (y_top + y_bot) // 2,
                          text=str(val), font=("Courier New", 12, "bold"), fill=GREEN)

        # Dibuja el elemento que sale encima (índice n)
        i = n
        y_bot = base_y - i * ITEM_H
        y_top = y_bot - ITEM_H
        x_l   = (W - ITEM_W) // 2 + offset_x
        x_r   = (W + ITEM_W) // 2 + offset_x
        alpha = max(0, 1 - offset_x / CANVAS_W)
        # Simula desvanecimiento cambiando el borde
        border = GREEN if offset_x < CANVAS_W // 2 else BORDER
        c.create_rectangle(x_l, y_top, x_r, y_bot,
                           fill="#002a15", outline=border, width=2)
        c.create_text((x_l + x_r) // 2, (y_top + y_bot) // 2,
                      text=self._pop_val_preview,
                      font=("Courier New", 12, "bold"), fill=GREEN)

    # ═══════════════════════════════════════════════════════
    #  OPERACIONES
    # ═══════════════════════════════════════════════════════
    def _snapshot(self):
        return copy.deepcopy(self.pila.to_list())

    def _push(self):
        val = self.entry.get().strip()
        if not val:
            self._set_status("Ingresa un valor antes de PUSH.", "warn")
            self._log("PUSH fallido: campo vacio.", "err")
            return
        try:
            snap = self._snapshot()
            self.pila.push(val)
            self._historial.append(("PUSH", snap))
            if len(self._historial) > 20:
                self._historial.pop(0)
            self.total_ops += 1
            self.highlight = []
            self._render()  # render previo (sin tope todavía)
            self.entry.delete(0, "end")
            # Anima entrada
            self._anim_push(callback=None)
            self._set_status(f'PUSH -> "{val}" agregado al tope.', "ok")
            self._log(f'PUSH -> "{val}" en [{len(self.pila)-1}]', "push")
        except OverflowError as e:
            self._set_status(str(e), "warn")
            self._log(str(e), "err")

    def _pop(self):
        if self.pila.vacia:
            self._set_status("Pila vacia. Nada que extraer.", "err")
            return
        snap = self._snapshot()
        val  = self.pila.peek()
        self._pop_val_preview = val
        self.pila.pop()
        self._historial.append(("POP", snap))
        if len(self._historial) > 20:
            self._historial.pop(0)
        self.total_ops += 1
        self.highlight = []

        def after_anim():
            self._render()
            self._set_status(f'POP -> "{val}" eliminado del tope.', "warn")
            self._log(f'POP <- "{val}" extraido de [{len(self.pila)}]', "pop")

        self._anim_pop(val, after_anim)

    def _peek(self):
        if self.pila.vacia:
            self._set_status("Pila vacia.", "err")
            return
        val = self.pila.peek()
        self.total_ops += 1
        self.highlight  = [len(self.pila) - 1]
        self.hl_color   = BLUE
        self._render()
        self._set_status(f'PEEK -> Tope: "{val}" (sin eliminar).', "info")
        self._log(f'PEEK -> tope es "{val}" en [{len(self.pila)-1}]', "info")
        self.root.after(1400, self._clear_hl)

    def _clear(self):
        if self.pila.vacia:
            return
        n    = len(self.pila)
        snap = self._snapshot()
        self.pila.clear()
        self._historial.append(("CLEAR", snap))
        if len(self._historial) > 20:
            self._historial.pop(0)
        self.total_ops += 1
        self.highlight  = []
        self._render()
        self._set_status(f"Pila limpiada. {n} elemento(s) eliminados.", "err")
        self._log(f"CLEAR -> {n} elemento(s) eliminados.", "err")

    def _undo(self):
        if not self._historial:
            self._set_status("Sin operaciones para deshacer.", "warn")
            return
        accion, snap = self._historial.pop()
        self.pila.from_list(snap)
        self.total_ops += 1
        self.highlight  = []
        self._render()
        self._set_status(f'DESHACER -> revertido "{accion}".', "undo")
        self._log(f'UNDO -> "{accion}" revertido. Pila: {snap}', "undo")

    def _buscar(self):
        val = self.search_entry.get().strip()
        if not val:
            self._set_status("Ingresa un valor para buscar.", "warn")
            return
        resultados = self.pila.buscar(val)
        self.total_ops += 1
        if resultados:
            self.highlight = resultados
            self.hl_color  = AMBER
            self._render()
            pos = ", ".join(f"[{i}]" for i in resultados)
            self._set_status(f'BUSCAR -> "{val}" encontrado en {pos}.', "search")
            self._log(f'BUSCAR -> "{val}" en posiciones {pos}.', "search")
            self.root.after(2000, self._clear_hl)
        else:
            self.highlight = []
            self._render()
            self._set_status(f'BUSCAR -> "{val}" no encontrado.', "err")
            self._log(f'BUSCAR -> "{val}" no existe en la pila.', "err")

    def _guardar(self):
        if self.pila.vacia:
            self._set_status("La pila esta vacia. Nada que guardar.", "warn")
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".txt",
            filetypes=[("Archivo de texto", "*.txt"), ("JSON", "*.json")],
            title="Guardar pila")
        if not path:
            return
        datos = self.pila.to_list()
        try:
            with open(path, "w", encoding="utf-8") as f:
                json.dump({"pila": datos, "timestamp": time.strftime("%Y-%m-%d %H:%M:%S")}, f, indent=2)
            self._set_status(f"Pila guardada en {path.split('/')[-1]}.", "ok")
            self._log(f'GUARDAR -> "{path.split("/")[-1]}" ({len(datos)} elementos).', "save")
        except Exception as e:
            self._set_status(f"Error al guardar: {e}", "err")

    def _cargar(self):
        path = filedialog.askopenfilename(
            filetypes=[("Archivo de texto", "*.txt"), ("JSON", "*.json")],
            title="Cargar pila")
        if not path:
            return
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            datos = data.get("pila", [])
            if not isinstance(datos, list):
                raise ValueError("Formato invalido")
            snap = self._snapshot()
            self.pila.from_list(datos)
            self._historial.append(("CARGAR", snap))
            self.total_ops += 1
            self.highlight  = []
            self._render()
            self._set_status(f"Pila cargada: {len(datos)} elemento(s).", "ok")
            self._log(f'CARGAR -> "{path.split("/")[-1]}" ({len(datos)} elementos).', "save")
        except Exception as e:
            self._set_status(f"Error al cargar: {e}", "err")
            self._log(f"CARGAR fallido: {e}", "err")

    # ── Helpers internos ──────────────────────────────────
    def _clear_hl(self):
        self.highlight = []
        self._render()

    def _set_status(self, msg, mode="ok"):
        colors = {"ok": GREEN, "warn": AMBER, "err": RED,
                  "info": BLUE, "undo": PURPLE, "search": AMBER}
        color = colors.get(mode, GREEN_DIM)
        self.status_var.set(msg)
        self.dot.itemconfig(self._dot_oval, fill=color)
        if self._blink_job:
            self.root.after_cancel(self._blink_job)
        self._blink_job = self.root.after(3500, lambda:
            self.dot.itemconfig(self._dot_oval, fill=GREEN_DIM))

    def _log(self, msg, tag="dim"):
        ts = time.strftime("%H:%M:%S")
        self.log_text.config(state="normal")
        self.log_text.insert("end", ts + "  ", "ts")
        self.log_text.insert("end", msg + "\n", tag)
        self.log_text.config(state="disabled")
        self.log_text.see("end")


