    #  CONSTRUCCIÓN DE LA UI
    # ═══════════════════════════════════════════════════════
    def _build_ui(self):
        self.root.title("Pila LIFO — Visualizador")
        self.root.configure(bg=BG)
        self.root.resizable(False, False)

        # Título
        hdr = tk.Frame(self.root, bg=BG)
        hdr.pack(pady=(16, 4))
        tk.Label(hdr, text="PILA LIFO",
                 font=("Courier New", 22, "bold"), fg=GREEN, bg=BG).pack()
        tk.Label(hdr, text="LAST IN  -  FIRST OUT  -  STACK SIMULATOR",
                 font=("Courier New", 8), fg=GREEN_DIM, bg=BG).pack(pady=(2, 0))

        # Separador
        tk.Frame(self.root, bg=BORDER, height=1).pack(fill="x", padx=20, pady=6)

        # Cuerpo
        body = tk.Frame(self.root, bg=BG)
        body.pack(padx=20, pady=6)

        self._build_canvas(body)   # col 0
        self._build_right(body)    # col 1

    # ── Canvas ────────────────────────────────────────────
    def _build_canvas(self, parent):
        left = tk.Frame(parent, bg=BG)
        left.grid(row=0, column=0, padx=(0, 18), sticky="n")

        tk.Label(left, text="VISUALIZACION DE LA PILA",
                 font=("Courier New", 8), fg=GREEN_DIM, bg=BG).pack(anchor="w", pady=(0, 5))

        self.canvas = tk.Canvas(left, width=CANVAS_W, height=CANVAS_H,
                                bg=PANEL, highlightthickness=1,
                                highlightbackground=BORDER)
        self.canvas.pack()

    # ── Panel derecho ─────────────────────────────────────
    def _build_right(self, parent):
        right = tk.Frame(parent, bg=BG)
        right.grid(row=0, column=1, sticky="n")

        self._build_ops(right)
        self._build_extra(right)
        self._build_stats(right)
        self._build_log_panel(right)

