import tkinter as tk
from tkinter import filedialog, messagebox
import time
import json
import copy

# ── Paleta de colores ──────────────────────────────────────
BG        = "#050f0a"
PANEL     = "#0a1a0f"
GREEN     = "#00ff88"
GREEN_DIM = "#00aa55"
AMBER     = "#ffaa00"
RED       = "#ff4444"
BLUE      = "#88ccff"
PURPLE    = "#cc88ff"
TEXT      = "#c0ffd8"
DARK_BG   = "#000d06"
BORDER    = "#004422"

MAX_SIZE = 10
ITEM_H   = 44
ITEM_W   = 220
CANVAS_W = 340
CANVAS_H = 500

ANIM_STEPS = 10
ANIM_DELAY = 18   # ms por frame


# ── Clase Pila ─────────────────────────────────────────────
class Pila:
    def __init__(self):
        self._datos = []

    def push(self, valor):
        if len(self._datos) >= MAX_SIZE:
            raise OverflowError("Pila llena (max. 10 elementos)")
        self._datos.append(str(valor))

    def pop(self):
        if not self._datos:
            raise IndexError("Pila vacia")
        return self._datos.pop()

    def peek(self):
        if not self._datos:
            raise IndexError("Pila vacia")
        return self._datos[-1]

    def buscar(self, valor):
        """Devuelve lista de índices donde aparece el valor."""
        v = str(valor)
        return [i for i, x in enumerate(self._datos) if x == v]

    def clear(self):
        self._datos.clear()

    def to_list(self):
        return list(self._datos)

    def from_list(self, lst):
        self._datos = [str(x) for x in lst[:MAX_SIZE]]

    def __len__(self):
        return len(self._datos)

    def __iter__(self):
        return iter(self._datos)

    @property
    def vacia(self):
        return len(self._datos) == 0


# ── App principal ──────────────────────────────────────────
class AppPila:
    def __init__(self, root):
        self.root = root
        self.pila = Pila()
        self.total_ops  = 0
        self.highlight  = []   # índices resaltados (buscar/peek)
        self.hl_color   = GREEN
        self._blink_job = None
        self._anim_job  = None

        # Historial para UNDO: lista de snapshots [(accion, datos)]
        self._historial = []

        self._build_ui()
        self._log("Sistema inicializado.", tag="dim")
        self._render()

