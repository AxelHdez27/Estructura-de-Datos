# ─── DATOS ───────────────────────────────────────────────────────────────────

ESTADOS = {
    "YUC": ("Mérida",        "Yucatán"),
    "CAM": ("Campeche",      "Campeche"),
    "QRO": ("Cancún",        "Quintana Roo"),
    "TAB": ("Villahermosa",  "Tabasco"),
    "CHI": ("Tuxtla Gtz.",   "Chiapas"),
    "OAX": ("Oaxaca",        "Oaxaca"),
    "VER": ("Veracruz",      "Veracruz"),
}

CONEXIONES = [
    ("YUC", "QRO",  718,  310, "3.5 h"),
    ("YUC", "CAM",  350,  185, "2.5 h"),
    ("CAM", "TAB",  620,  380, "5.5 h"),
    ("TAB", "CHI",  480,  250, "4.0 h"),
    ("TAB", "VER",  890,  475, "6.0 h"),
    ("CHI", "OAX", 1150,  550, "8.5 h"),
    ("OAX", "VER",  960,  465, "6.5 h"),
]

# Posiciones relativas en el widget del grafo (0.0–1.0)
POSICIONES = {
    "QRO": (0.55, 0.05),
    "YUC": (0.30, 0.25),
    "CAM": (0.15, 0.50),
    "TAB": (0.42, 0.55),
    "CHI": (0.60, 0.72),
    "OAX": (0.80, 0.60),
    "VER": (0.85, 0.35),
}

# ─── LÓGICA ──────────────────────────────────────────────────────────────────

def construir_grafo():
    g = {e: {} for e in ESTADOS}
    for o, d, c, km, t in CONEXIONES:
        g[o][d] = {"costo": c, "km": km}
        g[d][o] = {"costo": c, "km": km}
    return g

def dijkstra(grafo, origen, destino):
    dist = {n: float("inf") for n in grafo}
    prev = {n: None for n in grafo}
    dist[origen] = 0
    heap = [(0, origen)]
    while heap:
        d, u = heapq.heappop(heap)
        if d > dist[u]: continue
        for v, datos in grafo[u].items():
            nd = d + datos["costo"]
            if nd < dist[v]:
                dist[v] = nd; prev[v] = u
                heapq.heappush(heap, (nd, v))
    cam = []; cur = destino
    while cur: cam.append(cur); cur = prev[cur]
    cam.reverse()
    return cam, dist[destino]

def inciso_a(grafo):
    nodos = list(ESTADOS.keys())
    mejor_c = float("inf"); mejor_r = None
    for inicio in nodos:
        otros = [n for n in nodos if n != inicio]
        for perm in permutations(otros):
            ruta = [inicio] + list(perm)
            c = 0; ok = True
            for i in range(len(ruta) - 1):
                a, b = ruta[i], ruta[i+1]
                if b in grafo[a]: c += grafo[a][b]["costo"]
                else: ok = False; break
            if ok and c < mejor_c: mejor_c = c; mejor_r = ruta
    return mejor_r, mejor_c

def inciso_b(grafo):
    ruta = ["QRO","YUC","CAM","TAB","CHI","OAX","VER","TAB"]
    c = sum(grafo[ruta[i]][ruta[i+1]]["costo"] for i in range(len(ruta)-1))
    return ruta, c

# ─── WORKER THREAD ───────────────────────────────────────────────────────────

class Worker(QThread):
    result = Signal(str, list, int)

    def __init__(self, modo, grafo):
        super().__init__()
        self.modo = modo
        self.grafo = grafo

    def run(self):
        if self.modo == "a":
            ruta, costo = inciso_a(self.grafo)
        else:
            ruta, costo = inciso_b(self.grafo)
        self.result.emit(self.modo, ruta, costo)

# ─── WIDGET DEL GRAFO ────────────────────────────────────────────────────────

class GrafoWidget(QWidget):
    nodo_clicked = Signal(str)

    TEAL    = QColor("#1de9b6")
    AMBER   = QColor("#ffc107")
    SURFACE = QColor("#1e2a2a")
    EDGE_C  = QColor("#2e4a4a")
    TEXT_C  = QColor("#e0f2f1")
    DIM_C   = QColor("#37474f")

    def __init__(self):
        super().__init__()
        self.grafo = construir_grafo()
        self.ruta_activa = []
        self.nodo_hover = None
        self.setMinimumSize(420, 360)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        self.setMouseTracking(True)

    def _pos(self, key):
        rx, ry = POSICIONES[key]
        m = 36
        w = self.width() - 2*m
        h = self.height() - 2*m
        return QPointF(m + rx * w, m + ry * h)

    def set_ruta(self, ruta):
        self.ruta_activa = ruta
        self.update()

    def paintEvent(self, event):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)

        # Fondo
        p.fillRect(self.rect(), self.SURFACE)

        ruta_aristas = set()
        if self.ruta_activa:
            for i in range(len(self.ruta_activa)-1):
                a, b = self.ruta_activa[i], self.ruta_activa[i+1]
                ruta_aristas.add((min(a,b), max(a,b)))

        R = 22

        # Aristas
        for o, d, costo, km, _ in CONEXIONES:
            key = (min(o,d), max(o,d))
            p0 = self._pos(o); p1 = self._pos(d)
            activa = key in ruta_aristas

            if activa:
                pen = QPen(self.TEAL, 2.5)
            else:
                pen = QPen(self.EDGE_C, 1.2)
            pen.setCapStyle(Qt.RoundCap)
            p.setPen(pen)

            # Acortar la línea para no solapar el círculo del nodo
            dx = p1.x() - p0.x(); dy = p1.y() - p0.y()
            dist = (dx**2 + dy**2)**0.5
            if dist == 0: continue
            ux = dx/dist; uy = dy/dist
            ps = QPointF(p0.x() + ux*R, p0.y() + uy*R)
            pe = QPointF(p1.x() - ux*R, p1.y() - uy*R)
            p.drawLine(ps, pe)

            # Etiqueta de costo en el centro de la arista
            mx = (p0.x()+p1.x())/2; my = (p0.y()+p1.y())/2
            label = f"${costo:,}"
            fm = p.fontMetrics()
            lw = fm.horizontalAdvance(label) + 8
            lh = fm.height() + 4
            bg = QColor("#0d1f1f") if not activa else QColor("#003333")
            p.fillRect(int(mx-lw/2), int(my-lh/2), lw, lh, bg)
            p.setPen(QPen(self.TEAL if activa else QColor("#546e7a")))
            p.setFont(QFont("Consolas", 8))
            p.drawText(int(mx-lw/2), int(my-lh/2), lw, lh,
                       Qt.AlignCenter, label)

        # Nodos
        for key in ESTADOS:
            pos = self._pos(key)
            cap, est = ESTADOS[key]
            en_ruta = key in self.ruta_activa
            es_hover = key == self.nodo_hover
            es_repetido = (self.ruta_activa.count(key) > 1)

            # Círculo
            if es_repetido:
                fill = QColor("#ff6f00")
                border = QColor("#ffab40")
            elif en_ruta:
                fill = QColor("#004d40")
                border = self.TEAL
            elif es_hover:
                fill = QColor("#1e3a3a")
                border = self.TEAL
            else:
                fill = QColor("#152020")
                border = self.DIM_C

            pen_w = 2.5 if (en_ruta or es_hover) else 1.2
            p.setPen(QPen(border, pen_w))
            p.setBrush(QBrush(fill))
            p.drawEllipse(pos, R, R)

            # Siglas
            p.setPen(QPen(self.TEAL if en_ruta else QColor("#90a4ae")))
            p.setFont(QFont("Consolas", 9, QFont.Bold))
            p.drawText(
                int(pos.x()-R), int(pos.y()-8), R*2, 16,
                Qt.AlignCenter, key
            )

            # Nombre bajo el nodo
            p.setPen(QPen(self.TEXT_C if en_ruta else QColor("#607d8b")))
            p.setFont(QFont("Segoe UI", 8))
            p.drawText(
                int(pos.x()-50), int(pos.y()+R+3), 100, 14,
                Qt.AlignCenter, cap
            )

    def mouseMoveEvent(self, event):
        R = 22
        prev = self.nodo_hover
        self.nodo_hover = None
        for key in ESTADOS:
            pos = self._pos(key)
            dx = event.position().x() - pos.x()
            dy = event.position().y() - pos.y()
            if dx*dx + dy*dy <= R*R:
                self.nodo_hover = key
                self.setCursor(Qt.PointingHandCursor)
                break
        else:
            self.setCursor(Qt.ArrowCursor)
        if self.nodo_hover != prev:
            self.update()

    def mousePressEvent(self, event):
        if self.nodo_hover:
            self.nodo_clicked.emit(self.nodo_hover)

