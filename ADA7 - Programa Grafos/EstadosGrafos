    # ── Lógica de botones ──
    def calcular(self, modo):
        if self.worker and self.worker.isRunning(): return
        self.btn_a.setEnabled(False); self.btn_b.setEnabled(False)
        txt = "Calculando ruta A..." if modo=="a" else "Calculando ruta B (con repetición)..."
        self.output.setPlainText(txt)
        self.worker = Worker(modo, self.grafo)
        self.worker.result.connect(self.on_result)
        self.worker.start()

    def on_result(self, modo, ruta, costo):
        self.btn_a.setEnabled(True); self.btn_b.setEnabled(True)
        if modo == "a":
            self.ruta_a = ruta; self.costo_a = costo
            self.stat_widgets["costo_a"].setText(f"${costo:,}")
            texto = self._formato_ruta(ruta, costo, "A — Sin repetir nodos")
        else:
            self.ruta_b = ruta; self.costo_b = costo
            self.stat_widgets["costo_b"].setText(f"${costo:,}")
            self.stat_widgets["pasos_b"].setText(str(len(ruta)))
            texto = self._formato_ruta(ruta, costo, "B — Repitiendo TAB (Villahermosa)")

        if self.costo_a is not None and self.costo_b is not None:
            diff = self.costo_b - self.costo_a
            self.stat_widgets["diff"].setText(f"${diff:,}")

        self.output.setPlainText(texto)
        self.grafo_widget.set_ruta(ruta)

    def _formato_ruta(self, ruta, costo, titulo):
        W = 56
        lines = []
        lines.append("═" * W)
        lines.append(f"  INCISO {titulo}")
        lines.append("═" * W)
        lines.append("")

        vistos = []
        for i, nodo in enumerate(ruta):
            cap, est = ESTADOS[nodo]
            rep = "  ← REPETIDO" if nodo in vistos else ""
            if i == 0:
                lines.append(f"  INICIO  [{nodo}]  {cap} — {est}")
            else:
                pn = ruta[i-1]
                c  = self.grafo[pn][nodo]["costo"]
                km = self.grafo[pn][nodo]["km"]
                lines.append(f"          │  ${c:,} MXN  ({km} km)")
                fin = "[FIN]  " if i == len(ruta)-1 else "       "
                lines.append(f"  {fin}  [{nodo}]  {cap} — {est}{rep}")
            vistos.append(nodo)

        repetidos = [n for j,n in enumerate(ruta) if ruta[:j].count(n)>0]
        lines.append("")
        lines.append("─" * W)
        lines.append(f"  Pasos totales            : {len(ruta)}")
        lines.append(f"  Estados únicos visitados : {len(set(ruta))} / 7")
        if repetidos:
            noms = ", ".join(f"{r} ({ESTADOS[r][0]})" for r in dict.fromkeys(repetidos))
            lines.append(f"  Nodo(s) repetido(s)      : {noms}")
        lines.append("─" * W)
        lines.append(f"  COSTO TOTAL              : ${costo:,} MXN")
        lines.append("═" * W)
        return "\n".join(lines)

    def on_nodo_click(self, key):
        cap, est = ESTADOS[key]
        vecinos = self.grafo[key]
        partes = [f"<b style='color:#1de9b6'>[{key}]</b>  {cap} — {est}"]
        conex = []
        for v, d in vecinos.items():
            vc, ve = ESTADOS[v]
            conex.append(f"  → {v} ({vc}): <b>${d['costo']:,}</b> MXN · {d['km']} km")
        partes.append("<br>".join(conex))
        self.nodo_label.setText("  |  ".join(partes))
        self.nodo_label.setStyleSheet("color:#b2dfdb; font-size:12px; font-family:'Consolas';")

    def reset(self):
        self.ruta_a = self.costo_a = None
        self.ruta_b = self.costo_b = None
        self.grafo_widget.set_ruta([])
        self.output.clear()
        for lbl in self.stat_widgets.values():
            lbl.setText("$—" if "$" in lbl.text() or lbl.text()=="$—" else "—")
            lbl.setText("—")
        self.nodo_label.setText("Haz clic en un nodo del grafo para ver su información")
        self.nodo_label.setStyleSheet("color:#546e7a; font-size:12px;")

