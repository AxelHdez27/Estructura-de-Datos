def styled_btn(text, color="default"):
    b = QPushButton(text)
    if color == "danger": b.setObjectName("btn-danger")
    elif color == "ok":   b.setObjectName("btn-ok")
    return b

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.grafo = Grafo()
        self.setWindowTitle("Editor de Grafos — TAD Completo")
        self.setMinimumSize(1100, 680)
        self.setStyleSheet(MAIN_STYLE)

        # ── Toolbar ──
        tb = QToolBar("Herramientas")
        tb.setMovable(False)
        tb.setStyleSheet("QToolBar{background:#080c12;border-bottom:1px solid #1e2a40;spacing:4px;padding:4px;}")
        self.addToolBar(tb)

        self.tool_actions = {}
        tools = [
            ("↖  Seleccionar", "select"),
            ("◉  Agregar Vértice", "vertex"),
            ("→  Agregar Arista", "edge"),
            ("✕  Eliminar", "delete"),
        ]
        for name, key in tools:
            a = QAction(name, self)
            a.setCheckable(True)
            a.triggered.connect(lambda checked, k=key: self._set_tool(k))
            tb.addAction(a)
            self.tool_actions[key] = a
        self.tool_actions["select"].setChecked(True)

        tb.addSeparator()
        load_btn = QAction("★  Ejemplo", self); load_btn.triggered.connect(self._load_example); tb.addAction(load_btn)
        layout_btn = QAction("⊞  Auto-distribuir", self); layout_btn.triggered.connect(self._auto_layout); tb.addAction(layout_btn)
        tb.addSeparator()
        hint_lbl = QLabel("  Doble clic en nodo/arista para editar · Clic derecho en nodo para menú  ")
        hint_lbl.setStyleSheet("color:#3a5070; font-size:11px;")
        tb.addWidget(hint_lbl)

        # ── Central ──
        central = QWidget(); self.setCentralWidget(central)
        main_lay = QHBoxLayout(central); main_lay.setContentsMargins(0,0,0,0); main_lay.setSpacing(0)

        splitter = QSplitter(Qt.Horizontal)
        main_lay.addWidget(splitter)

        # Canvas
        self.canvas = GrafoCanvas(self.grafo)
        self.canvas.selectionChanged.connect(self._on_selection)
        self.canvas.logMessage.connect(self._log)
        splitter.addWidget(self.canvas)

        # Side panel
        side = QTabWidget(); side.setFixedWidth(340)
        splitter.addWidget(side)
        splitter.setStretchFactor(0, 1)

        side.addTab(self._build_add_tab(),   "  Agregar  ")
        side.addTab(self._build_query_tab(), " Consultar ")
        side.addTab(self._build_ops_tab(),   " Operaciones ")
        side.addTab(self._build_log_tab(),   "   Log   ")

        # Status bar
        self.status = QStatusBar(); self.setStatusBar(self.status)
        self._update_status()

    def _set_tool(self, key):
        for k, a in self.tool_actions.items(): a.setChecked(k == key)
        self.canvas.set_mode(key)
        hints = {
            "select": "Seleccionar: arrastra nodos · doble clic para editar",
            "vertex": "Agregar Vértice: haz clic en el canvas",
            "edge":   "Agregar Arista: haz clic en nodo origen, luego en destino",
            "delete": "Eliminar: haz clic en el elemento a eliminar",
        }
        self.status.showMessage(hints.get(key, ""))

    def _load_example(self):
        self.canvas.load_example()
        self._update_status()

    def _auto_layout(self):
        self.canvas.auto_layout()

    def _update_status(self):
        g = self.grafo
        self.status.showMessage(
            f"  Vértices: {g.numVertices()}   Aristas: {g.numAristas()}   "
            f"Dirigidas: {len(g.aristasDirigidas())}   No dirigidas: {len(g.aristasNoDirigidas())}"
        )

    def _log(self, msg, level="info"):
        colors = {"ok": "#80d0a0", "err": "#ff8080", "info": "#80b0ff"}
        c = colors.get(level, "#c0c0c0")
        self.log_edit.append(f'<span style="color:#3a5070">[{level.upper()}]</span> <span style="color:{c}">{msg}</span>')
        self._update_status()

    def _on_selection(self, idx, typ):
        self._update_selected_info(idx, typ)

    def _update_selected_info(self, idx, typ):
        if typ == "vertex" and idx is not None:
            v = self.grafo._vertices.get(idx)
            if v:
                info = (f"<b>Vértice {idx}</b><br>"
                        f"Objeto: {v.objeto}<br>"
                        f"Grado: {self.grafo.grado(idx)}<br>"
                        f"Adyacentes: {self.grafo.verticesAdyacentes(idx)}<br>"
                        f"Aristas incidentes: {self.grafo.aristasIncidentes(idx)}<br>"
                        f"Grado entrada: {self.grafo.gradoEnt(idx)}<br>"
                        f"Grado salida: {self.grafo.gradoSalida(idx)}")
                self.sel_info.setText(info)
        elif typ == "edge" and idx is not None:
            a = self.grafo._aristas.get(idx)
            if a:
                info = (f"<b>Arista {idx}</b><br>"
                        f"Objeto: {a.objeto}<br>"
                        f"Tipo: {'DIRIGIDA →' if a.dirigida else 'NO DIRIGIDA —'}<br>"
                        f"Origen: V{a._origen.indice}<br>"
                        f"Destino: V{a._destino.indice}")
                self.sel_info.setText(info)
        else:
            self.sel_info.setText("<span style='color:#3a5070'>Nada seleccionado</span>")

    # ─────────────────────────────────────────────
    # BUILD TABS
    # ─────────────────────────────────────────────
    def _build_add_tab(self):
        w = QWidget(); lay = QVBoxLayout(w); lay.setContentsMargins(10,10,10,10)

        grp_v = QGroupBox("Nuevo Vértice"); fl = QFormLayout(grp_v)
        self.v_obj = QLineEdit(); self.v_obj.setPlaceholderText("ej: A, Ciudad, 42")
        fl.addRow("Objeto:", self.v_obj)
        btn_v = styled_btn("+ Agregar Vértice", "ok")
        btn_v.clicked.connect(self._add_vertex); fl.addRow(btn_v)
        lay.addWidget(grp_v)

        grp_e = QGroupBox("Nueva Arista"); fl2 = QFormLayout(grp_e)
        self.e_from = QSpinBox(); self.e_from.setRange(0, 9999)
        self.e_to   = QSpinBox(); self.e_to.setRange(0, 9999)
        self.e_obj  = QLineEdit(); self.e_obj.setPlaceholderText("ej: 5, ruta")
        self.e_dir  = QCheckBox("Arista Dirigida")
        fl2.addRow("Origen (v):", self.e_from)
        fl2.addRow("Destino (w):", self.e_to)
        fl2.addRow("Objeto:", self.e_obj)
        fl2.addRow(self.e_dir)
        btn_e = styled_btn("+ Agregar Arista", "ok")
        btn_e.clicked.connect(self._add_edge); fl2.addRow(btn_e)
        lay.addWidget(grp_e)
        lay.addStretch()
        return w

    def _build_query_tab(self):
        w = QWidget(); lay = QVBoxLayout(w); lay.setContentsMargins(10,10,10,10)

        # General
        grp_g = QGroupBox("Consultas Generales"); gl = QVBoxLayout(grp_g)
        for lbl, fn in [
            ("numVertices()",    lambda: self.grafo.numVertices()),
            ("numAristas()",     lambda: self.grafo.numAristas()),
            ("vertices()",       lambda: self.grafo.vertices()),
            ("aristas()",        lambda: self.grafo.aristas()),
            ("aristasDirigidas()",    lambda: self.grafo.aristasDirigidas()),
            ("aristasNoDirigidas()",  lambda: self.grafo.aristasNoDirigidas()),
        ]:
            b = QPushButton(lbl)
            b.clicked.connect(lambda _, f=fn, l=lbl: self._show_result(l, f()))
            gl.addWidget(b)
        lay.addWidget(grp_g)

        # Por vértice
        grp_v = QGroupBox("Consultas por Vértice v"); vl = QVBoxLayout(grp_v)
        row = QHBoxLayout(); row.addWidget(QLabel("Índice v:"))
        self.q_v = QSpinBox(); self.q_v.setRange(0, 9999); row.addWidget(self.q_v)
        vl.addLayout(row)
        for lbl, fn in [
            ("grado(v)",                 lambda v: self.grafo.grado(v)),
            ("verticesAdyacentes(v)",    lambda v: self.grafo.verticesAdyacentes(v)),
            ("aristasIncidentes(v)",     lambda v: self.grafo.aristasIncidentes(v)),
            ("gradoEnt(v)",              lambda v: self.grafo.gradoEnt(v)),
            ("gradoSalida(v)",           lambda v: self.grafo.gradoSalida(v)),
            ("aristasIncidentesEnt(v)",  lambda v: self.grafo.aristasIncidentesEnt(v)),
            ("aristasIncidentesSal(v)",  lambda v: self.grafo.aristasIncidentesSal(v)),
            ("verticesAdyacentesEnt(v)", lambda v: self.grafo.verticesAdyacentesEnt(v)),
            ("verticesAdyacentesSal(v)", lambda v: self.grafo.verticesAdyacentesSal(v)),
        ]:
            b = QPushButton(lbl)
            b.clicked.connect(lambda _, f=fn, l=lbl: self._show_result(l, f(self.q_v.value())))
            vl.addWidget(b)
        lay.addWidget(grp_v)

        # Por arista
        grp_e = QGroupBox("Consultas por Arista e"); el = QVBoxLayout(grp_e)
        row2 = QHBoxLayout(); row2.addWidget(QLabel("Índice e:"))
        self.q_e = QSpinBox(); self.q_e.setRange(0, 9999); row2.addWidget(self.q_e)
        el.addLayout(row2)
        for lbl, fn in [
            ("verticesFinales(e)", lambda e: self.grafo.verticesFinales(e)),
            ("esDirigida(e)",      lambda e: self.grafo.esDirigida(e)),
            ("origen(e)",          lambda e: self.grafo.origen(e)),
            ("destino(e)",         lambda e: self.grafo.destino(e)),
        ]:
            b = QPushButton(lbl)
            b.clicked.connect(lambda _, f=fn, l=lbl: self._show_result(l, f(self.q_e.value())))
            el.addWidget(b)
        lay.addWidget(grp_e)

        # 2 parámetros
        grp_2 = QGroupBox("Consultas con 2 parámetros"); tl = QVBoxLayout(grp_2)
        r3 = QHBoxLayout()
        r3.addWidget(QLabel("v:")); self.q_v2 = QSpinBox(); self.q_v2.setRange(0,9999); r3.addWidget(self.q_v2)
        r3.addWidget(QLabel("w/e:")); self.q_w2 = QSpinBox(); self.q_w2.setRange(0,9999); r3.addWidget(self.q_w2)
        tl.addLayout(r3)
        b_adj = QPushButton("esAdyacente(v, w)")
        b_adj.clicked.connect(lambda: self._show_result("esAdyacente", self.grafo.esAdyacente(self.q_v2.value(), self.q_w2.value())))
        b_opp = QPushButton("opuesto(v, e)")
        b_opp.clicked.connect(lambda: self._show_result("opuesto", self.grafo.opuesto(self.q_v2.value(), self.q_w2.value())))
        tl.addWidget(b_adj); tl.addWidget(b_opp)
        lay.addWidget(grp_2)

        # Result
        self.result_lbl = QLabel("— resultado —"); self.result_lbl.setObjectName("result-label")
        self.result_lbl.setWordWrap(True)
        lay.addWidget(self.result_lbl)
        lay.addStretch()
        return w

    def _build_ops_tab(self):
        w = QWidget(); lay = QVBoxLayout(w); lay.setContentsMargins(10,10,10,10)

        # Selected info
        self.sel_info = QLabel("<span style='color:#3a5070'>Nada seleccionado</span>")
        self.sel_info.setObjectName("result-label"); self.sel_info.setWordWrap(True)
        self.sel_info.setMinimumHeight(90)
        lay.addWidget(self.sel_info)

        # Eliminar
        grp_d = QGroupBox("Eliminar"); dl = QFormLayout(grp_d)
        self.del_v = QSpinBox(); self.del_v.setRange(0, 9999)
        btn_dv = styled_btn("eliminaVertice(v)", "danger"); btn_dv.clicked.connect(self._op_del_v)
        self.del_e = QSpinBox(); self.del_e.setRange(0, 9999)
        btn_de = styled_btn("eliminaArista(e)", "danger"); btn_de.clicked.connect(self._op_del_e)
        dl.addRow("Vértice:", self.del_v); dl.addRow(btn_dv)
        dl.addRow("Arista:", self.del_e); dl.addRow(btn_de)
        lay.addWidget(grp_d)

        # Dirección
        grp_dir = QGroupBox("Modificar Dirección"); rl = QFormLayout(grp_dir)
        self.dir_e = QSpinBox(); self.dir_e.setRange(0, 9999)
        self.dir_v = QSpinBox(); self.dir_v.setRange(0, 9999)
        rl.addRow("Arista e:", self.dir_e)
        rl.addRow("Vértice v:", self.dir_v)
        for lbl, fn in [
            ("convierteNoDirigida(e)",   self._op_cnd),
            ("invierteDireccion(e)",     self._op_inv),
            ("asignaDireccionDesde(e,v)",self._op_add),
            ("asignaDireccionA(e,v)",    self._op_ada),
        ]:
            b = QPushButton(lbl); b.clicked.connect(fn); rl.addRow(b)
        lay.addWidget(grp_dir)
        lay.addStretch()
        return w

    def _build_log_tab(self):
        w = QWidget(); lay = QVBoxLayout(w)
        self.log_edit = QTextEdit(); self.log_edit.setReadOnly(True)
        lay.addWidget(self.log_edit)
        btn_clear = styled_btn("Limpiar log")
        btn_clear.clicked.connect(self.log_edit.clear)
        lay.addWidget(btn_clear)
        return w

    # ─────────────────────────────────────────────
    # ACTIONS
    # ─────────────────────────────────────────────
    def _add_vertex(self):
        try:
            obj = self.v_obj.text() or None
            idx = self.grafo.insertaVertice(obj)
            # place it at center + small offset
            cx = self.canvas.width() / 2 + (self.grafo.numVertices()-1)*30
            cy = self.canvas.height() / 2
            self.canvas.pos[idx] = QPointF(cx, cy)
            self.canvas.update()
            self._log(f"insertaVertice('{obj}') → índice {idx}", "ok")
            self.v_obj.clear()
        except Exception as ex:
            self._log(str(ex), "err")

    def _add_edge(self):
        try:
            v = self.e_from.value(); w = self.e_to.value()
            obj = self.e_obj.text() or None
            if self.e_dir.isChecked():
                idx = self.grafo.insertaAristaDirigida(v, w, obj)
                self._log(f"insertaAristaDirigida(V{v},V{w}) → E{idx}", "ok")
            else:
                idx = self.grafo.insertaArista(v, w, obj)
                self._log(f"insertaArista(V{v},V{w}) → E{idx}", "ok")
            self.canvas.update()
            self.e_obj.clear()
        except Exception as ex:
            self._log(str(ex), "err")

    def _show_result(self, label, result):
        self.result_lbl.setText(f"<b style='color:#4a9eff'>{label}</b><br>{result}")

    def _safe(self, fn, *args):
        try:
            fn(*args)
            self.canvas.update()
            self._update_status()
        except Exception as ex:
            self._log(str(ex), "err")

    def _op_del_v(self):
        v = self.del_v.value()
        def do():
            if v in self.canvas.pos: del self.canvas.pos[v]
            self.grafo.eliminaVertice(v)
            self.canvas._select(None, None)
            self._log(f"eliminaVertice({v})", "ok")
        self._safe(do)

    def _op_del_e(self):
        e = self.del_e.value()
        def do():
            self.grafo.eliminaArista(e)
            self.canvas._select(None, None)
            self._log(f"eliminaArista({e})", "ok")
        self._safe(do)

    def _op_cnd(self):
        e = self.dir_e.value()
        def do():
            self.grafo.convierteNoDirigida(e)
            self._log(f"convierteNoDirigida({e})", "ok")
        self._safe(do)

    def _op_inv(self):
        e = self.dir_e.value()
        def do():
            self.grafo.invierteDireccion(e)
            self._log(f"invierteDireccion({e})", "ok")
        self._safe(do)

    def _op_add(self):
        e, v = self.dir_e.value(), self.dir_v.value()
        def do():
            self.grafo.asignaDireccionDesde(e, v)
            self._log(f"asignaDireccionDesde(E{e}, V{v})", "ok")
        self._safe(do)

    def _op_ada(self):
        e, v = self.dir_e.value(), self.dir_v.value()
        def do():
            self.grafo.asignaDireccionA(e, v)
            self._log(f"asignaDireccionA(E{e}, V{v})", "ok")
        self._safe(do)


