#  TAD GRAFO
# ══════════════════════════════════════════════════════════
class Vertice:
    def __init__(self, indice, objeto=None):
        self.indice = indice
        self.objeto = objeto

class Arista:
    def __init__(self, indice, origen, destino, objeto=None, dirigida=False):
        self.indice  = indice
        self._origen  = origen
        self._destino = destino
        self.objeto  = objeto
        self.dirigida = dirigida

class Grafo:
    def __init__(self):
        self._vertices   = {}
        self._aristas    = {}
        self._adyacencia = {}
        self._cv = 0
        self._ca = 0

    # ── Consultas básicas ──
    def numVertices(self):  return len(self._vertices)
    def numAristas(self):   return len(self._aristas)
    def vertices(self):     return list(self._vertices.keys())
    def aristas(self):      return list(self._aristas.keys())

    def grado(self, v):
        self._vv(v); return len(self._adyacencia[v])

    def verticesAdyacentes(self, v):
        self._vv(v)
        s = set()
        for a in self._adyacencia[v]:
            s.add(a._destino.indice if a._origen.indice == v else a._origen.indice)
        return list(s)

    def aristasIncidentes(self, v):
        self._vv(v); return [a.indice for a in self._adyacencia[v]]

    def verticesFinales(self, e):
        self._ve(e); a = self._aristas[e]; return [a._origen.indice, a._destino.indice]

    def opuesto(self, v, e):
        self._vv(v); self._ve(e); a = self._aristas[e]
        if a._origen.indice == v:   return a._destino.indice
        if a._destino.indice == v:  return a._origen.indice
        raise ValueError(f"V{v} no es extremo de E{e}")

    def esAdyacente(self, v, w):
        self._vv(v); self._vv(w)
        return any(a._origen.indice == w or a._destino.indice == w for a in self._adyacencia[v])

    # ── Dirigidas ──
    def aristasDirigidas(self):   return [i for i,a in self._aristas.items() if a.dirigida]
    def aristasNoDirigidas(self): return [i for i,a in self._aristas.items() if not a.dirigida]

    def gradoEnt(self, v):
        self._vv(v); return len(self.aristasIncidentesEnt(v))
    def gradoSalida(self, v):
        self._vv(v); return len(self.aristasIncidentesSal(v))

    def aristasIncidentesEnt(self, v):
        self._vv(v)
        return [a.indice for a in self._adyacencia[v] if a.dirigida and a._destino.indice == v]
    def aristasIncidentesSal(self, v):
        self._vv(v)
        return [a.indice for a in self._adyacencia[v] if a.dirigida and a._origen.indice == v]

    def verticesAdyacentesEnt(self, v):
        self._vv(v)
        return [a._origen.indice for a in self._adyacencia[v] if a.dirigida and a._destino.indice == v]
    def verticesAdyacentesSal(self, v):
        self._vv(v)
        return [a._destino.indice for a in self._adyacencia[v] if a.dirigida and a._origen.indice == v]

    def destino(self, e):
        self._ve(e); a = self._aristas[e]
        if not a.dirigida: raise ValueError(f"E{e} no es dirigida")
        return a._destino.indice
    def origen(self, e):
        self._ve(e); a = self._aristas[e]
        if not a.dirigida: raise ValueError(f"E{e} no es dirigida")
        return a._origen.indice
    def esDirigida(self, e):
        self._ve(e); return self._aristas[e].dirigida

    # ── Modificaciones ──
    def insertaVertice(self, objeto=None):
        idx = self._cv; self._cv += 1
        v = Vertice(idx, objeto)
        self._vertices[idx] = v
        self._adyacencia[idx] = []
        return idx

    def insertaArista(self, v, w, objeto=None):
        self._vv(v); self._vv(w)
        idx = self._ca; self._ca += 1
        a = Arista(idx, self._vertices[v], self._vertices[w], objeto, False)
        self._aristas[idx] = a
        self._adyacencia[v].append(a)
        if v != w: self._adyacencia[w].append(a)
        return idx

    def insertaAristaDirigida(self, v, w, objeto=None):
        self._vv(v); self._vv(w)
        idx = self._ca; self._ca += 1
        a = Arista(idx, self._vertices[v], self._vertices[w], objeto, True)
        self._aristas[idx] = a
        self._adyacencia[v].append(a)
        if v != w: self._adyacencia[w].append(a)
        return idx

    def eliminaVertice(self, v):
        self._vv(v)
        for e in list(self.aristasIncidentes(v)): self.eliminaArista(e)
        del self._vertices[v]; del self._adyacencia[v]

    def eliminaArista(self, e):
        self._ve(e); a = self._aristas[e]
        v, w = a._origen.indice, a._destino.indice
        self._adyacencia[v] = [x for x in self._adyacencia[v] if x.indice != e]
        if v != w:
            self._adyacencia[w] = [x for x in self._adyacencia[w] if x.indice != e]
        del self._aristas[e]

    def convierteNoDirigida(self, e):
        self._ve(e); self._aristas[e].dirigida = False
    def invierteDireccion(self, e):
        self._ve(e); a = self._aristas[e]
        if not a.dirigida: raise ValueError(f"E{e} no es dirigida")
        a._origen, a._destino = a._destino, a._origen
    def asignaDireccionDesde(self, e, v):
        self._ve(e); self._vv(v); a = self._aristas[e]
        w = a._destino.indice if a._origen.indice == v else a._origen.indice
        a.dirigida = True; a._origen = self._vertices[v]; a._destino = self._vertices[w]
    def asignaDireccionA(self, e, v):
        self._ve(e); self._vv(v); a = self._aristas[e]
        w = a._origen.indice if a._destino.indice == v else a._destino.indice
        a.dirigida = True; a._origen = self._vertices[w]; a._destino = self._vertices[v]

    def _vv(self, v):
        if v not in self._vertices: raise ValueError(f"Vértice {v} no existe")
    def _ve(self, e):
        if e not in self._aristas: raise ValueError(f"Arista {e} no existe")


# ══════════════════════════════════════════════════════════
#  CANVAS WIDGET
# ══════════════════════════════════════════════════════════
RADIO   = 24
C_BG    = QColor("#0d1117")
C_GRID  = QColor("#1a1f2e")
C_NODE  = QColor("#1c2a4a")
C_NODE_SEL  = QColor("#0d3060")
C_NODE_BORDER = QColor("#4a9eff")
C_NODE_SEL_BORDER = QColor("#00d4ff")
C_LABEL = QColor("#e0eaff")
C_EDGE  = QColor("#3a5080")
C_EDGE_DIR = QColor("#ff6b8a")
C_EDGE_SEL = QColor("#ffd700")
C_ARROW = QColor("#ff6b8a")
C_IDX   = QColor("#7090c0")
C_OBJ   = QColor("#a0c4ff")

class GrafoCanvas(QWidget):
    selectionChanged = pyqtSignal(object, str)  # (item, type: 'vertex'|'edge'|None)
    logMessage       = pyqtSignal(str, str)      # (msg, level)

    def __init__(self, grafo: Grafo):
        super().__init__()
        self.grafo = grafo
        self.pos   = {}          # indice_vertice -> QPointF
        self.selected      = None
        self.selected_type = None
        self._drag_node    = None
        self._drag_offset  = QPointF()
        self._edge_src     = None  # for edge-drawing mode
        self.mode          = "select"   # select | vertex | edge | delete
        self.setMouseTracking(True)
        self.setMinimumSize(400, 400)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        self.setCursor(Qt.ArrowCursor)

    def set_mode(self, m):
        self.mode = m
        self._edge_src = None
        cursors = {
            "select": Qt.ArrowCursor, "vertex": Qt.CrossCursor,
            "edge": Qt.PointingHandCursor, "delete": Qt.ForbiddenCursor
        }
        self.setCursor(cursors.get(m, Qt.ArrowCursor))
        self.update()

    # ── Painting ──
    def paintEvent(self, _):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        self._draw_bg(p)
        self._draw_edges(p)
        self._draw_vertices(p)
        if self._edge_src is not None:
            self._draw_edge_hint(p)

    def _draw_bg(self, p):
        p.fillRect(self.rect(), C_BG)
        pen = QPen(C_GRID, 1)
        p.setPen(pen)
        step = 40
        for x in range(0, self.width(), step):
            p.drawLine(x, 0, x, self.height())
        for y in range(0, self.height(), step):
            p.drawLine(0, y, self.width(), y)

    def _draw_edges(self, p):
        for idx, arista in self.grafo._aristas.items():
            v, w = arista._origen.indice, arista._destino.indice
            if v not in self.pos or w not in self.pos: continue
            pv = self.pos[v]; pw = self.pos[w]
            selected = (self.selected_type == 'edge' and self.selected == idx)
            color = C_EDGE_SEL if selected else (C_EDGE_DIR if arista.dirigida else C_EDGE)
            pen = QPen(color, 2.5 if selected else 2)
            pen.setStyle(Qt.SolidLine)
            p.setPen(pen)

            if v == w:
                # self-loop
                self._draw_loop(p, pv, color, arista)
                continue

            # offset if bidirectional edges exist
            offset = self._edge_offset(v, w)
            pv2, pw2 = self._offset_points(pv, pw, offset)

            p.drawLine(pv2, pw2)

            # label (objeto + indice)
            mx = (pv2.x() + pw2.x()) / 2
            my = (pv2.y() + pw2.y()) / 2
            p.setPen(QPen(C_IDX))
            f = QFont("Consolas", 8)
            p.setFont(f)
            lbl = f"e{idx}"
            if arista.objeto: lbl += f":{arista.objeto}"
            p.drawText(QPointF(mx + 4, my - 4), lbl)

            if arista.dirigida:
                self._draw_arrow(p, pv2, pw2, color)

    def _edge_offset(self, v, w):
        # Check if there's also an edge w->v
        for a in self.grafo._aristas.values():
            if a._origen.indice == w and a._destino.indice == v:
                return 10
        return 0

    def _offset_points(self, p1, p2, d):
        if d == 0: return p1, p2
        dx = p2.x() - p1.x(); dy = p2.y() - p1.y()
        length = math.hypot(dx, dy)
        if length == 0: return p1, p2
        nx = -dy / length * d; ny = dx / length * d
        return QPointF(p1.x()+nx, p1.y()+ny), QPointF(p2.x()+nx, p2.y()+ny)

    def _draw_loop(self, p, pos, color, arista):
        r = RADIO + 18
        p.setPen(QPen(color, 2))
        p.drawEllipse(QRectF(pos.x() - r/2, pos.y() - RADIO - r, r, r))

    def _draw_arrow(self, p, src, dst, color):
        dx = dst.x() - src.x(); dy = dst.y() - src.y()
        length = math.hypot(dx, dy)
        if length < 1: return
        ux = dx / length; uy = dy / length
        tip = QPointF(dst.x() - ux * RADIO, dst.y() - uy * RADIO)
        size = 12
        perp_x = -uy * size * 0.4; perp_y = ux * size * 0.4
        b1 = QPointF(tip.x() - ux*size + perp_x, tip.y() - uy*size + perp_y)
        b2 = QPointF(tip.x() - ux*size - perp_x, tip.y() - uy*size - perp_y)
        poly = QPolygonF([tip, b1, b2])
        p.setBrush(QBrush(color)); p.setPen(Qt.NoPen)
        p.drawPolygon(poly)

    def _draw_vertices(self, p):
        for idx, v in self.grafo._vertices.items():
            if idx not in self.pos: continue
            pos = self.pos[idx]
            selected = (self.selected_type == 'vertex' and self.selected == idx)
            is_src    = (self._edge_src == idx)

            # glow for selected
            if selected or is_src:
                glow = QColor(0, 200, 255, 40) if not is_src else QColor(255, 200, 0, 50)
                p.setBrush(QBrush(glow)); p.setPen(Qt.NoPen)
                p.drawEllipse(pos, RADIO+8, RADIO+8)

            # fill
            grad = QLinearGradient(pos.x(), pos.y()-RADIO, pos.x(), pos.y()+RADIO)
            if selected:
                grad.setColorAt(0, QColor("#1a4080")); grad.setColorAt(1, QColor("#0a2050"))
            elif is_src:
                grad.setColorAt(0, QColor("#806000")); grad.setColorAt(1, QColor("#503800"))
            else:
                grad.setColorAt(0, QColor("#1c2a4a")); grad.setColorAt(1, QColor("#0d1825"))
            p.setBrush(QBrush(grad))

            border = C_NODE_SEL_BORDER if selected else (QColor("#ffd700") if is_src else C_NODE_BORDER)
            p.setPen(QPen(border, 2.5 if selected else 1.8))
            p.drawEllipse(pos, RADIO, RADIO)

            # index label
            p.setPen(QPen(C_LABEL))
            p.setFont(QFont("Consolas", 10, QFont.Bold))
            p.drawText(QRectF(pos.x()-RADIO, pos.y()-RADIO, RADIO*2, RADIO*2),
                       Qt.AlignCenter, str(idx))

            # object label below
            if v.objeto:
                p.setPen(QPen(C_OBJ))
                p.setFont(QFont("Consolas", 8))
                p.drawText(QPointF(pos.x() - 30, pos.y() + RADIO + 14), str(v.objeto))

    def _draw_edge_hint(self, p):
        if self._edge_src not in self.pos: return
        src = self.pos[self._edge_src]
        mp  = self.mapFromGlobal(QCursor.pos())
        pen = QPen(QColor("#ffd70088"), 2, Qt.DashLine)
        p.setPen(pen)
        p.drawLine(src, QPointF(mp.x(), mp.y()))

    # ── Mouse ──
    def mousePressEvent(self, e):
        pt = QPointF(e.pos())
        if self.mode == "vertex" and e.button() == Qt.LeftButton:
            self._add_vertex_at(pt)
        elif self.mode == "edge" and e.button() == Qt.LeftButton:
            self._edge_click(pt)
        elif self.mode == "delete" and e.button() == Qt.LeftButton:
            self._delete_at(pt)
        elif self.mode == "select":
            if e.button() == Qt.LeftButton:
                node = self._node_at(pt)
                if node is not None:
                    self._drag_node   = node
                    self._drag_offset = pt - self.pos[node]
                    self._select('vertex', node)
                else:
                    edge = self._edge_at(pt)
                    if edge is not None: self._select('edge', edge)
                    else: self._select(None, None)
            elif e.button() == Qt.RightButton:
                node = self._node_at(pt)
                if node is not None: self._show_node_menu(node, e.globalPos())

    def mouseMoveEvent(self, e):
        if self._drag_node is not None and self.mode == "select":
            self.pos[self._drag_node] = QPointF(e.pos()) - self._drag_offset
            self.update()
        elif self.mode == "edge" and self._edge_src is not None:
            self.update()

    def mouseReleaseEvent(self, e):
        self._drag_node = None

    def mouseDoubleClickEvent(self, e):
        pt = QPointF(e.pos())
        node = self._node_at(pt)
        if node is not None:
            self._edit_vertex(node)
            return
        edge = self._edge_at(pt)
        if edge is not None:
            self._edit_edge(edge)

    def _add_vertex_at(self, pt):
        idx = self.grafo.insertaVertice(f"v{self.grafo._cv}")
        self.pos[idx] = pt
        self._select('vertex', idx)
        self.logMessage.emit(f"insertaVertice() → índice {idx}", "ok")
        self.update()

    def _edge_click(self, pt):
        node = self._node_at(pt)
        if node is None: return
        if self._edge_src is None:
            self._edge_src = node
            self.logMessage.emit(f"Arista: origen = V{node}. Haz clic en el destino.", "info")
            self.update()
        else:
            src = self._edge_src; self._edge_src = None
            # ask directed?
            dlg = EdgeTypeDialog(self)
            if dlg.exec_() == QDialog.Accepted:
                obj = dlg.obj_edit.text() or None
                if dlg.directed_cb.isChecked():
                    idx = self.grafo.insertaAristaDirigida(src, node, obj)
                    self.logMessage.emit(f"insertaAristaDirigida(V{src},V{node}) → E{idx}", "ok")
                else:
                    idx = self.grafo.insertaArista(src, node, obj)
                    self.logMessage.emit(f"insertaArista(V{src},V{node}) → E{idx}", "ok")
                self._select('edge', idx)
            self.update()

    def _delete_at(self, pt):
        node = self._node_at(pt)
        if node is not None:
            self.grafo.eliminaVertice(node)
            del self.pos[node]
            self.logMessage.emit(f"eliminaVertice({node})", "ok")
            self._select(None, None); self.update(); return
        edge = self._edge_at(pt)
        if edge is not None:
            self.grafo.eliminaArista(edge)
            self.logMessage.emit(f"eliminaArista({edge})", "ok")
            self._select(None, None); self.update()

    def _node_at(self, pt):
        for idx, p in self.pos.items():
            if math.hypot(pt.x()-p.x(), pt.y()-p.y()) <= RADIO + 4:
                return idx
        return None

    def _edge_at(self, pt):
        for idx, a in self.grafo._aristas.items():
            v, w = a._origen.indice, a._destino.indice
            if v not in self.pos or w not in self.pos: continue
            pv = self.pos[v]; pw = self.pos[w]
            if self._dist_to_segment(pt, pv, pw) < 8:
                return idx
        return None

    def _dist_to_segment(self, p, a, b):
        dx = b.x()-a.x(); dy = b.y()-a.y()
        if dx == dy == 0: return math.hypot(p.x()-a.x(), p.y()-a.y())
        t = max(0, min(1, ((p.x()-a.x())*dx+(p.y()-a.y())*dy)/(dx*dx+dy*dy)))
        return math.hypot(p.x()-(a.x()+t*dx), p.y()-(a.y()+t*dy))

    def _select(self, typ, idx):
        self.selected = idx; self.selected_type = typ
        self.selectionChanged.emit(idx, typ or "none")
        self.update()

    def _edit_vertex(self, idx):
        v = self.grafo._vertices[idx]
        dlg = EditVertexDialog(str(v.objeto or ""), self)
        if dlg.exec_() == QDialog.Accepted:
            v.objeto = dlg.label_edit.text() or None
            self.update()

    def _edit_edge(self, idx):
        a = self.grafo._aristas[idx]
        dlg = EditEdgeDialog(str(a.objeto or ""), a.dirigida, self)
        if dlg.exec_() == QDialog.Accepted:
            a.objeto   = dlg.label_edit.text() or None
            a.dirigida = dlg.directed_cb.isChecked()
            self.update()

    def _show_node_menu(self, node, gpos):
        from PyQt5.QtWidgets import QMenu
        menu = QMenu(self)
        menu.setStyleSheet(MENU_STYLE)
        menu.addAction(f"✏ Editar V{node}",   lambda: self._edit_vertex(node))
        menu.addAction(f"🗑 Eliminar V{node}", lambda: self._delete_node_confirm(node))
        menu.exec_(gpos)

    def _delete_node_confirm(self, node):
        self.grafo.eliminaVertice(node)
        del self.pos[node]
        self.logMessage.emit(f"eliminaVertice({node})", "ok")
        self._select(None, None); self.update()

    def auto_layout(self):
        vs = self.grafo.vertices()
        if not vs: return
        n = len(vs); cx = self.width()/2; cy = self.height()/2; r = min(cx, cy) * 0.7
        for i, v in enumerate(vs):
            angle = 2 * math.pi * i / n - math.pi/2
            self.pos[v] = QPointF(cx + r*math.cos(angle), cy + r*math.sin(angle))
        self.update()

    def load_example(self):
        g = self.grafo
        for v in list(g.vertices()): g.eliminaVertice(v)
        self.pos.clear()
        a = g.insertaVertice("A"); b = g.insertaVertice("B")
        c = g.insertaVertice("C"); d = g.insertaVertice("D")
        e = g.insertaVertice("E")
        g.insertaArista(a, b, "5")
        g.insertaAristaDirigida(b, c, "3")
        g.insertaAristaDirigida(c, d, "7")
        g.insertaArista(d, e, "2")
        g.insertaAristaDirigida(e, a, "4")
        g.insertaArista(b, d, "6")
        self.auto_layout()
        self.logMessage.emit("Ejemplo cargado (5 vértices, 6 aristas)", "info")


