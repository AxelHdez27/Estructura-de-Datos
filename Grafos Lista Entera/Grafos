QLabel  { color:#a0b4d0; font-size:12px; }
QLineEdit { background:#1c2a4a; border:1px solid #2a3a5a; color:#e0eaff;
            padding:5px; border-radius:4px; font-family:Consolas; }
QCheckBox { color:#e0eaff; }
