MENU = """
╔════════════════════════════════════════╗
║     MENÚ DE ORDENAMIENTO               ║
╠════════════════════════════════════════╣
║  1. Radix Sort                         ║
║  2. Heap Sort                          ║
║  3. Quick Sort                         ║
║  4. Shell Sort                         ║
║  5. Salir                              ║
╚════════════════════════════════════════╝"""


def ejecutar_radix() -> None:
    print("\n── Radix Sort ──")
    print("  a) Ingresar números manualmente")
    print("  b) Generar números aleatorios (0 – 10 000)")
    opcion = input("  Elige una opción (a/b): ").strip().lower()

    if opcion == "b":
        cantidad = pedir_cantidad()
        nums = [randint(0, 10_000) for _ in range(cantidad)]
        print(f"  Números generados: {nums}")
    else:
        cantidad = pedir_cantidad()
        nums = pedir_numeros(cantidad, solo_positivos=True)

    resultado = radix_sort(nums[:])          # copia para no modificar el original
    print(f"\n  Original : {nums}")
    print(f"  Ordenado : {resultado}")


def ejecutar_metodo(nombre: str, funcion) -> None:
    print(f"\n── {nombre} ──")
    cantidad = pedir_cantidad()
    nums = pedir_numeros(cantidad)
    resultado = funcion(nums[:])
    print(f"\n  Original : {nums}")
    print(f"  Ordenado : {resultado}")


def main() -> None:
    print("\n¡Bienvenido al programa de ordenamiento!")

    while True:
        print(MENU)
        opcion = input("Selecciona una opción (1-5): ").strip()

        if opcion == "1":
            ejecutar_radix()
        elif opcion == "2":
            ejecutar_metodo("Heap Sort", heap_sort)
        elif opcion == "3":
            ejecutar_metodo("Quick Sort", quick_sort)
        elif opcion == "4":
            ejecutar_metodo("Shell Sort", shell_sort)
        elif opcion == "5":
            print("\n¡Hasta luego! \n")
            break
        else:
            print("\n   Opción no válida, elige entre 1 y 5.")

        input("\nPresiona Enter para continuar...")


if __name__ == "__main__":
    main()
