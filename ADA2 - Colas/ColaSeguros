    print("  ╚══════════════════════════════════════════════════╝")
    print()


# ─────────────────────────────────────────────
#  Parseo flexible de entrada
# ─────────────────────────────────────────────

def parsear_entrada(entrada: str):
    """
    Acepta: 'C 1', 'c1', 'C1', 'c 1', 'A3', 'a 3', 'E', 'Q', '?'
    Retorna (comando_upper, numero_int_o_None)
    """
    entrada = entrada.strip()
    if not entrada:
        return None, None

    comando = entrada[0].upper()
    resto = entrada[1:].strip()

    numero = None
    if resto:
        try:
            numero = int(resto)
        except ValueError:
            numero = -1  # indica que se escribió algo inválido como número

    return comando, numero


# ─────────────────────────────────────────────
#  Bucle principal
# ─────────────────────────────────────────────

def main():
    sistema = SistemaAtencion(SERVICIOS)
    mostrar_ayuda(SERVICIOS)

    while True:
        try:
            entrada = input("  >> ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n  [Sistema finalizado]")
            break

        if not entrada:
            continue

        comando, numero = parsear_entrada(entrada)

        # ── Salir ──────────────────────────────────────────────────────────
        if comando == "Q":
            print("\n   Sistema cerrado. ¡Hasta luego!\n")
            break

        # ── Ayuda ──────────────────────────────────────────────────────────
        elif comando == "?":
            mostrar_ayuda(SERVICIOS)

        # ── Estado ─────────────────────────────────────────────────────────
        elif comando == "E":
            sistema.mostrar_estado()

        # ── Llegada de cliente ─────────────────────────────────────────────
        elif comando == "C":
            if numero is None:
                print(f"\n   Falta el número de servicio. Ejemplo: C 1 o C1")
                print(f"     Servicios válidos: {list(SERVICIOS.keys())}\n")
            elif numero == -1:
                print(f"\n  El número de servicio debe ser un entero. Ejemplo: C 1\n")
            else:
                try:
                    ticket = sistema.llega_cliente(numero)
                    nombre_serv = SERVICIOS[numero]
                    print()
                    print(f"   Cliente registrado exitosamente")
                    print(f"  ┌──────────────────────────────────────┐")
                    print(f"  │  Servicio  : {nombre_serv:<25}│")
                    print(f"  │  Ticket    : {ticket:04d}                      │")
                    print(f"  │  En espera : {sistema.colas[numero].tamaño():<25}│")
                    print(f"  └──────────────────────────────────────┘")
                    print()
                except ValueError as e:
                    print(f"\n  ⚠ {e}\n")

        # ── Atender cliente ────────────────────────────────────────────────
        elif comando == "A":
            if numero is None:
                print(f"\n   Falta el número de servicio. Ejemplo: A 1 o A1")
                print(f"     Servicios válidos: {list(SERVICIOS.keys())}\n")
            elif numero == -1:
                print(f"\n   El número de servicio debe ser un entero. Ejemplo: A 3\n")
            else:
                try:
                    ticket = sistema.atender_cliente(numero)
                    nombre_serv = SERVICIOS[numero]
                    print()
                    print(f"   ¡LLAMANDO NÚMERO {ticket:04d}!")
                    print(f"  ┌──────────────────────────────────────┐")
                    print(f"  │  Servicio  : {nombre_serv:<25}│")
                    print(f"  │  Número    : {ticket:04d}                      │")
                    print(f"  │  En espera : {sistema.colas[numero].tamaño():<25}│")
                    print(f"  └──────────────────────────────────────┘")
                    print()
                except (ValueError, IndexError) as e:
                    print(f"\n   {e}\n")

        # ── Comando desconocido ────────────────────────────────────────────
        else:
            print(f"\n   Comando '{comando}' no reconocido.")
            print(f"     Comandos válidos: C, A, E, Q, ?")
            print(f"     Escriba ? para ver la ayuda.\n")


if __name__ == "__main__":
    main()
    
