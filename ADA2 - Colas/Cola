#  Demostración
# ─────────────────────────────────────────────

def imprimir_tabla(cola_a_vals, cola_b_vals, resultado_vals):
    ancho = 10
    print(f"\n{'Cola A':>{ancho}}  {'Cola B':>{ancho}}  {'Resultado':>{ancho}}")
    print("-" * (ancho * 3 + 4))
    for a, b, r in zip(cola_a_vals, cola_b_vals, resultado_vals):
        print(f"{a:>{ancho}}  {b:>{ancho}}  {r:>{ancho}}")


def ingresar_cola(nombre: str) -> tuple:
    """
    Pide al usuario ingresar un número por fila.
    Presionar Enter en blanco termina el ingreso.
    """
    print(f"\n  Ingreso de {nombre}")
    print("  Ingrese un número por fila. [Enter vacío para terminar]")
    cola = Cola()
    valores = []
    while True:
        entrada = input(f"  {nombre} [{len(valores)+1}]: ").strip()
        if entrada == "":
            if not valores:
                print("  ⚠ Debe ingresar al menos un número.")
                continue
            break
        try:
            num = int(entrada)
            cola.encolar(num)
            valores.append(num)
        except ValueError:
            print("  ⚠ Solo se permiten números enteros. Intente de nuevo.")
    return cola, valores


if __name__ == "__main__":
    print("=" * 42)
    print("   SUMA ELEMENTO A ELEMENTO DE DOS COLAS")
    print("=" * 42)

    cola_a, datos_a = ingresar_cola("Cola A")

    while True:
        cola_b, datos_b = ingresar_cola("Cola B")
        if len(datos_b) == len(datos_a):
            break
        print(f"\n   Cola B tiene {len(datos_b)} elemento(s) pero Cola A tiene {len(datos_a)}.")
        print("  Ambas colas deben tener la misma cantidad de filas. Intente de nuevo.")

    print(f"\n  Cola A    : {cola_a}")
    print(f"  Cola B    : {cola_b}")

    cola_resultado = sumar_colas(cola_a, cola_b)

    print(f"  Resultado : {cola_resultado}")

    # Reconstruir lista resultado para la tabla
    res_vals = []
    temp = cola_resultado._frente
    while temp:
        res_vals.append(temp.dato)
        temp = temp.siguiente

    imprimir_tabla(datos_a, datos_b, res_vals)
    print()
